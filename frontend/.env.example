# ============================================================
# Rezerveo frontend — build-time environment variables (Vite)
# Copy to "frontend/.env". Only VITE_* vars are exposed to the client bundle.
# ============================================================

# Base URL the frontend uses for API calls.
# Default "/api" works in production (nginx proxies it) and in dev (Vite proxy).
# Override with an absolute URL only if the API lives on a different origin.
VITE_API_URL=/api
