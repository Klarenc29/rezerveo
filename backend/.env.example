# ============================================================
# Rezerveo backend — environment variables
# Copy to "backend/.env" and fill in real values.
# ============================================================

# ----- Server -----
NODE_ENV=development
PORT=5000

# Comma-separated list of allowed origins for CORS.
# In production behind the bundled nginx, the frontend uses a same-origin
# relative /api path so CORS is not strictly required, but set this when the
# API is called from another origin (e.g. local Vite dev server).
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ----- SMTP (Nodemailer) -----
# Works with any SMTP provider (your own server, Mailtrap, Gmail, Mailgun...).
# Auth (SMTP_USER/PASS) is OPTIONAL — leave blank for credential-less servers.
#
# >>> For the maildev container on the shared "rezerveo" network (recommended
#     for testing on this server), use the internal SMTP port 1025, no auth:
#   SMTP_HOST=mail_dev
#   SMTP_PORT=1025
#   SMTP_SECURE=false
#   SMTP_USER=
#   SMTP_PASS=
#   (view captured mail at the maildev web UI, e.g. http://<server>:32774)
#
# Example for Mailtrap sandbox:
#   SMTP_HOST=sandbox.smtp.mailtrap.io
#   SMTP_PORT=2525
SMTP_HOST=mail_dev
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ----- Mail addressing -----
# IMPORTANT: most providers (Zoho, Gmail, Outlook, ...) only let you send mail
# whose From address is the AUTHENTICATED mailbox (SMTP_USER) or a verified
# alias of it. A mismatch causes: "553 Sender is not allowed to relay emails".
#
# Leave MAIL_FROM blank to automatically use SMTP_USER (safest), or set it to
# SMTP_USER / a verified alias. A display name is allowed, e.g.:
#   MAIL_FROM="Rezerveo Website <info@rezerveo.al>"   (info@... = your SMTP_USER)
MAIL_FROM=

# Where booking/demo requests are delivered (any address is fine here).
MAIL_TO=info@rezerveo.al

# ----- Rate limiting (anti-spam) -----
# Window in minutes and max submissions per IP within that window.
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=5
