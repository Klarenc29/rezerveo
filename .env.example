# ============================================================
# Rezerveo — root compose-level environment variables
# Copy to ".env" and adjust. Used by docker-compose.yml.
# Service-specific secrets live in backend/.env (see backend/.env.example).
# ============================================================

# Public port the nginx-served frontend is exposed on (host -> container 80)
FRONTEND_PORT=3000

# Public port the backend API is exposed on (host -> container 5000)
# nginx inside the frontend also proxies /api -> rezerveo-landing-api:5000
BACKEND_PORT=5000

# Node environment for the backend container
NODE_ENV=production
